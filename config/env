#!/usr/bin/bash

export EDITOR=vi
export STARSHIP_CONFIG="$HOME/dotfiles/config/starship.toml"

eval "$(starship init bash)"
eval "$(mise activate bash)"

export PATH="$HOME/dotfiles/work/bin:$PATH"
export PATH="$HOME/dotfiles/bin:$PATH"
export PATH="$HOME/go/bin:$PATH"

export PATH="$HOME/.config/emacs/bin:$PATH"

bind '"\e[A": history-search-backward'
bind '"\e[B": history-search-forward'
bind '"\e[OA": history-search-backward'
bind '"\e[OB": history-search-forward'

source "$HOME/dotfiles/config/.git-completion.bash"
